# Supabase project URL (no /rest/v1 at the end)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Prefer service role key for batch upsert scripts
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# Optional fallback if service role is not provided
# SUPABASE_API_KEY="YOUR_ANON_OR_PUBLISHABLE_KEY"

# Optional defaults for script execution
SUPABASE_TABLE="ping-video"
SUPABASE_CONFLICT_COLUMN="id"
